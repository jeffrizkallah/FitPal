# ─── Database ────────────────────────────────────────────────────────────────
# Neon DB — copy your connection string from neon.tech dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# NextAuth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── AI ───────────────────────────────────────────────────────────────────────
# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Production notes ─────────────────────────────────────────────────────────
# For production deployment on Vercel, set all vars above in the Vercel dashboard.
# NEXTAUTH_URL should be your production domain: https://your-app.vercel.app
# DATABASE_URL should point to the Neon PRODUCTION branch (not dev).
# Run after deploying: npm run db:seed (against the production DATABASE_URL)
